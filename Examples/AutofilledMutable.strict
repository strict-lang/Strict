has number
mutable text
has logger
TotalLength Number
	AutofilledMutable(5).TotalLength is 5
	AutofilledMutable(5, "abc").TotalLength is 8
	number + text.Length
Run
	logger.Log("TotalLength: " + AutofilledMutable(5).TotalLength)
	logger.Log("TotalLength with text: " + AutofilledMutable(5, "abc").TotalLength)