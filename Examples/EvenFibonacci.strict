has number
Sum Number
	EvenFibonacci(100).Sum is 44
	mutable first = 1
	mutable second = 1
	mutable total = 0
	for Range(1, number)
		let next = first + second
		if next >= number
			return total
		total = AddIfEven(total, next)
		first = second
		second = next
	total
AddIfEven(current Number, next Number) Number
	EvenFibonacci(100).AddIfEven(2, 4) is 6
	EvenFibonacci(100).AddIfEven(2, 3) is 2
	if next % 2 is 0
		current + next
	else
		current