has number
Sum Number
	mutable first = 1
	mutable second = 1
	mutable sum = 0
	for Range(1, number)
		let next = first + second
		if next >= number
			return sum
		sum = AddIfEven(sum, next)
		first = second
		second = next
	sum
AddIfEven(mutable current Number, next Number) Number
	if next % 2 is 0
		current.Increment(next)
	current