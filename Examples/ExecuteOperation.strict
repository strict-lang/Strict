has registers
TryOperationExecution(instruction) Register
	if registers.Length < 2
		Error "OperandsRequired"
	GetOperationResult(instruction, registers(1), registers(0))
	registers(1)
GetOperationResult(instruction, left Register, right Register) Number
	if instruction.InstructionType is
		InstructionType.Add then left + right
		InstructionType.Subtract then left - right
		InstructionType.Multiply then left * right
		InstructionType.Divide then left / right