has resultTypeName Text
has memberNames Texts
has memberValues Texts
MemberCount Number
	memberNames.Length
to Text
	resultTypeName + ": " + JoinMembers
JoinMembers Text
	mutable result = ""
	mutable index = 0
	for memberNames
		if result is not ""
			result = result + "; "
		result = result + value + "=" + memberValues(index)
		index = index + 1
	result
