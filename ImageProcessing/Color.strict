has Red Byte
has Green Byte
has Blue Byte
has Alpha Byte = 255
from(colorValue)
	Red = Byte(colorValue.Red * 255)
	Green = Byte(colorValue.Green * 255)
	Blue = Byte(colorValue.Blue * 255)
	Alpha = Byte(colorValue.Alpha * 255)
to ColorValue
	Color(1, 0, 0) to ColorValue is ColorValue(1, 0, 0)
	ColorValue(Red / 255, Green / 255, Blue / 255, Alpha / 255)