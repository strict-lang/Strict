has logger
Run(path)
	mutable image = Image(ImageLoader.from(path))
	AdjustBrightness(0.25).Process(image)
	let outputPath = inputPath.ChangeExtension("_output.jpg")
	ImageSaver.Save(outputPath, image.Colors, image.Size.Width, image.Size.Height)
	logger.Log("Processed image saved to: " + outputPath)
