has logger
has inputPath Text
Run
	mutable loader = ImageLoader.from(inputPath)
	mutable image = Image(Size(1, 1), loader.Colors)
	AdjustBrightness(0.25).Process(image)
	constant outputPath = inputPath + "_processed.png"
	ImageSaver.Save(outputPath, image.Colors, image.Size.Width, image.Size.Height)
	logger.Log("Processed image saved to: " + outputPath)
