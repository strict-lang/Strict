has memberName Text
has typeName Text
has memberKind Text
has initialValue Text
IsMutable Boolean
	memberKind is "mutable"
IsConstant Boolean
	memberKind is "constant"
IsPublic Boolean
	memberName.StartsWith("A")
to Text
	if memberKind is "mutable"
		return "mutable " + memberName + " " + typeName
	if memberKind is "constant"
		return "constant " + memberName + " = " + initialValue
	"has " + memberName + " " + typeName
