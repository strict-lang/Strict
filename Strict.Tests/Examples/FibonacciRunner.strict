has count Number
has logger
Compute Number
	FibonacciRunner(10).Compute is 55
	FibonacciRunner(5).Compute is 5
	mutable first = 1
	mutable second = 1
	for Range(2, count - 1)
		let next = first + second
		first = second
		second = next
	second
Run
	constant bigFib = FibonacciRunner(10)
	constant smallFib = FibonacciRunner(5)
	logger.Log("Fibonacci(10) = " + bigFib.Compute)
	logger.Log("Fibonacci(5) = " + smallFib.Compute)
