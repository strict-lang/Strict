has first Number
has second Number
has logger
Add Number
	SimpleCalculator(2, 3).Add is 5
	SimpleCalculator(0, 0).Add is 0
	SimpleCalculator(10, 20).Add is 30
	first + second
Multiply Number
	SimpleCalculator(2, 3).Multiply is 6
	SimpleCalculator(5, 4).Multiply is 20
	first * second
Run
	let calc = SimpleCalculator(2, 3)
	logger.Log("2 + 3 = " + calc.Add)
	logger.Log("2 * 3 = " + calc.Multiply)